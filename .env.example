
# =====================
# Django
# =====================
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
TZ=UTC

# =====================
# OpenAI
# =====================
# Required by OpenAI SDK when running build_criteria_table/check_criterion_ai.
OPENAI_API_KEY=
OPENAI_CRITERIA_MODEL=gpt-4.1-mini

# =====================
# Telegram notifications
# =====================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

ADMIN_LOG_CHAT_ID=


# =====================
# Monitoring / observability
# =====================
APP_LOG_FILE=logs/app.log
APP_JOB_ERROR_LOG_FILE=logs/jobs_errors.log
CRITICAL_ENV_VARS=DJANGO_SECRET_KEY
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# =====================
# Google access mode (pipeline/validation)
# public_link | oauth_owner | service_account
# =====================
GOOGLE_ACCESS_MODE=oauth_owner

# OAuth owner files
GOOGLE_OAUTH_CLIENT_SECRET_PATH=/app/creds/google/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=/app/creds/google/token.json
GOOGLE_OAUTH_REDIRECT_URI=

# Service account file
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/app/creds/service_account.json

# Google Drive upload targets
GOOGLE_REVIEW_FOLDER_ID=
GOOGLE_REVIEW_FOLDER_MAP=
GOOGLE_REVIEW_DUPLICATE_STRATEGY=update

# Parent report contacts (optional for pipeline/full runner)
PARENT_REPORTS_CONTACTS_JSON=
PARENT_REPORTS_CONTACTS_CSV=

# PDF conversion
PDF_CONVERT_MODE=libreoffice
LIBREOFFICE_BIN=libreoffice
PDF_OUTPUT_ROOT=

# =====================
# Legacy scripts (school_journal-main)
# =====================
GOOGLE_CLASSES_URL=
PARENT_REPORTS_SPREADSHEET_URL=
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_FROM=

EDUPAGE_USERNAME=
EDUPAGE_PASSWORD=
EDUPAGE_SCHOOL=
EDUPAGE_TARGET_TEACHER_ID=
EDUPAGE_CHAT_ID=
EDUPAGE_OPENED_TIMESTAMP=
EDUPAGE_UID=
EDUPAGE_UIDSGN=
EDUPAGE_TEST_MESSAGE=Test message
