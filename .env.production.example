# Copy this file to .env.production on the server and replace placeholders.
# Do not commit .env.production.

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=<SERVER_IP>
DJANGO_CSRF_TRUSTED_ORIGINS=http://<SERVER_IP>
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
CRITICAL_ENV_VARS=DJANGO_SECRET_KEY
TZ=UTC

# PostgreSQL
POSTGRES_DB=school_journal
POSTGRES_USER=school_journal
POSTGRES_PASSWORD=<change-me>
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://school_journal:<password>@db:5432/school_journal

# OpenAI
OPENAI_API_KEY=
OPENAI_CRITERIA_MODEL=gpt-4.1-mini

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
ADMIN_LOG_CHAT_ID=

# Google access mode: public_link | oauth_owner | service_account
GOOGLE_ACCESS_MODE=oauth_owner
GOOGLE_OAUTH_CLIENT_SECRET_PATH=/app/creds/google/client_secret.json
GOOGLE_OAUTH_TOKEN_PATH=/app/creds/google/token.json
GOOGLE_OAUTH_REDIRECT_URI=http://<SERVER_IP>/links/google/oauth/callback/
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/app/creds/service_account.json
GOOGLE_REVIEW_FOLDER_ID=
GOOGLE_REVIEW_FOLDER_MAP=
GOOGLE_REVIEW_DUPLICATE_STRATEGY=update

# Parent report contacts
PARENT_REPORTS_CONTACTS_JSON=
PARENT_REPORTS_CONTACTS_CSV=

# PDF conversion
PDF_CONVERT_MODE=libreoffice
LIBREOFFICE_BIN=libreoffice
PDF_OUTPUT_ROOT=

# Monitoring / observability
APP_LOG_FILE=/app/logs/app.log
APP_JOB_ERROR_LOG_FILE=/app/logs/jobs_errors.log
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0

# Legacy scripts
GOOGLE_CLASSES_URL=
PARENT_REPORTS_SPREADSHEET_URL=
SMTP_LOGIN=
SMTP_PASSWORD=
SMTP_FROM=
EDUPAGE_USERNAME=
EDUPAGE_PASSWORD=
EDUPAGE_SCHOOL=
EDUPAGE_TARGET_TEACHER_ID=
EDUPAGE_CHAT_ID=
EDUPAGE_OPENED_TIMESTAMP=
EDUPAGE_UID=
EDUPAGE_UIDSGN=
EDUPAGE_TEST_MESSAGE=Test message
